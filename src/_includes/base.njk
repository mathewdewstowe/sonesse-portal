<!doctype html>
<html lang="en-US">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' />

	<title>{{ title }}</title>
	<link rel="canonical" href="{{ canonical }}" />
	<meta property="og:locale" content="en_US" />
	<meta property="og:type" content="{{ ogType | default('article') }}" />
	<meta property="og:title" content="{{ title }}" />
	<meta property="og:url" content="{{ ogUrl | default(canonical) }}" />
	<meta property="og:site_name" content="Sonesse" />
	<meta property="article:modified_time" content="{{ modifiedTime }}" />
	<meta name="twitter:card" content="summary_large_image" />
	{% if twitterLabel1 %}
	<meta name="twitter:label1" content="{{ twitterLabel1 }}" />
	<meta name="twitter:data1" content="{{ twitterData1 }}" />
	{% endif %}
	{% if jsonLd %}
	<script type="application/ld+json">{{ jsonLd | safe }}</script>
	{% endif %}

	<!-- Fonts -->
	<link rel="dns-prefetch" href="https://fonts.googleapis.com/" />
	<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700&subset=latin,latin-ext" />
	<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Inter+Tight:400,600,700" />

	<!-- Styles -->
	<link rel="stylesheet" href="/css/styles.css" />

	<!-- Favicons -->
	{% include "partials/head-favicons.njk" %}
</head>
<body class="{{ bodyClass }}">

<a href="#main-content" class="sr-only">Skip to main content</a>

{% include "partials/header.njk" %}

<div class="header-spacer"></div>

<main id="main-content" role="main">
{{ content | safe }}
</main>

{% include "partials/footer.njk" %}
{% include "partials/popup-form.njk" %}

<!-- Video Lightbox -->
<div id="video-lightbox" class="video-lightbox-overlay">
	<div class="video-lightbox__inner">
		<button class="video-lightbox__close" aria-label="Close">&times;</button>
		<video class="video-lightbox__video" controls></video>
	</div>
</div>

<!-- Scroll to Top -->
<button class="scroll-to-top" aria-label="Back to top">&uarr;</button>

<!-- Mobile Menu Overlay -->
<nav class="mobile-menu" aria-label="Mobile Menu">
	<a href="/on-premise/">On-Premise</a>
	<a href="/use-cases/">Use Cases</a>
	<a href="/blog/">Blog</a>
	<a href="/demo/">Sign Up</a>
</nav>

<script src="/js/main.js" defer></script>
</body>
</html>
