<!doctype html>
<html lang="en-US" class="no-js">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0" /><meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' />

	<!-- This site is optimized with the Yoast SEO plugin v27.1.1 - https://yoast.com/product/yoast-seo-wordpress/ -->
	<title>{{ title }}</title>
	<link rel="canonical" href="{{ canonical }}" />
	<meta property="og:locale" content="en_US" />
	<meta property="og:type" content="{{ ogType | default('article') }}" />
	<meta property="og:title" content="{{ title }}" />
	<meta property="og:url" content="{{ ogUrl | default(canonical) }}" />
	<meta property="og:site_name" content="Umified" />
	<meta property="article:modified_time" content="{{ modifiedTime }}" />
	<meta name="twitter:card" content="summary_large_image" />
	{% if twitterLabel1 %}
	<meta name="twitter:label1" content="{{ twitterLabel1 }}" />
	<meta name="twitter:data1" content="{{ twitterData1 }}" />
	{% endif %}
	<script type="application/ld+json" class="yoast-schema-graph">{{ jsonLd | safe }}</script>
	<!-- / Yoast SEO plugin. -->

{% include "partials/head-common.njk" %}

	{{ pageElementCss | safe }}

	{{ pageInlineStyles | safe }}

{% include "partials/head-cookie-config.njk" %}
{{ vcCustomCss | safe }}
{% include "partials/head-favicons.njk" %}
{% include "partials/head-wp-custom-css.njk" %}

{% include "partials/head-deferred-css.njk" %}

