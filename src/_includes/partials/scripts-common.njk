<!-- Force consistent layout across all pages - runs AFTER Salient JS -->
<script type="text/javascript">
(function() {
  function getContainerWidth() {
    var winW = window.innerWidth;
    return winW >= 1340 ? '1260px' : 'calc(100% - 80px)';
  }
  function enforceLayout() {
    var w = getContainerWidth();
    // Force header height
    var header = document.getElementById('header-outer');
    if (header) {
      header.style.setProperty('height', '99px', 'important');
      header.style.setProperty('min-height', '99px', 'important');
      header.style.setProperty('max-height', '99px', 'important');
    }
    // Force header-space
    var headerSpace = document.getElementById('header-space');
    if (headerSpace) {
      headerSpace.style.setProperty('height', '99px', 'important');
      headerSpace.style.setProperty('max-height', '99px', 'important');
    }
    // Force logo size and vertical centering (margin-top = (99-43)/2 = 28px)
    var logo = document.querySelector('#logo img');
    if (logo) {
      logo.style.setProperty('height', '43px', 'important');
      logo.style.setProperty('max-height', '43px', 'important');
      logo.style.setProperty('width', 'auto', 'important');
    }
    var logoLink = document.getElementById('logo');
    if (logoLink) {
      logoLink.style.setProperty('margin-top', '28px', 'important');
      logoLink.style.setProperty('display', 'block', 'important');
    }
    // Force header container width — both width and max-width
    var headerContainer = document.querySelector('#header-outer header#top > .container');
    if (headerContainer) {
      headerContainer.style.setProperty('max-width', w, 'important');
      headerContainer.style.setProperty('width', w, 'important');
      headerContainer.style.setProperty('margin-left', 'auto', 'important');
      headerContainer.style.setProperty('margin-right', 'auto', 'important');
    }
    // Force content container widths
    var containers = document.querySelectorAll('.container-wrap .container');
    containers.forEach(function(c) {
      c.style.setProperty('max-width', w, 'important');
      c.style.setProperty('margin-left', 'auto', 'important');
      c.style.setProperty('margin-right', 'auto', 'important');
    });
    // Force row_col_wrap_12 inside full-width-section
    var rowWraps = document.querySelectorAll('.full-width-section > .row_col_wrap_12');
    rowWraps.forEach(function(rw) {
      rw.style.setProperty('max-width', w, 'important');
      rw.style.setProperty('margin-left', 'auto', 'important');
      rw.style.setProperty('margin-right', 'auto', 'important');
    });
    // Force nav font size
    var navLinks = document.querySelectorAll('nav .sf-menu > li > a');
    navLinks.forEach(function(a) {
      a.style.setProperty('font-size', '16px', 'important');
    });
  }
  // Run immediately (before DOMContentLoaded)
  enforceLayout();
  // Run after DOM ready — Salient JS also runs on DOMContentLoaded
  document.addEventListener('DOMContentLoaded', function() {
    enforceLayout();
    setTimeout(enforceLayout, 50);
    setTimeout(enforceLayout, 200);
    setTimeout(enforceLayout, 500);
    setTimeout(enforceLayout, 1000);
  });
  // Run on full load
  window.addEventListener('load', function() {
    enforceLayout();
    setTimeout(enforceLayout, 300);
  });
  // Run on resize
  window.addEventListener('resize', enforceLayout);
  // MutationObserver: re-enforce immediately if Salient JS mutates header styles
  if (window.MutationObserver) {
    var _obs = new MutationObserver(function(mutations) {
      var needsEnforce = false;
      mutations.forEach(function(m) {
        if (m.attributeName === 'style' || m.attributeName === 'class') needsEnforce = true;
      });
      if (needsEnforce) {
        _obs.disconnect();
        enforceLayout();
        _reattachObs();
      }
    });
    function _reattachObs() {
      var _h = document.getElementById('header-outer');
      var _hs = document.getElementById('header-space');
      var _l = document.getElementById('logo');
      var _li = document.querySelector('#logo img');
      if (_h) _obs.observe(_h, { attributes: true, attributeFilter: ['style','class'] });
      if (_hs) _obs.observe(_hs, { attributes: true, attributeFilter: ['style','class'] });
      if (_l) _obs.observe(_l, { attributes: true, attributeFilter: ['style','class'] });
      if (_li) _obs.observe(_li, { attributes: true, attributeFilter: ['style','class'] });
    }
    function _startObs() { _reattachObs(); }
    document.addEventListener('DOMContentLoaded', _startObs);
    window.addEventListener('load', _startObs);
  }
})();
</script>
