<!-- Hero -->
<section class="section use-cases-intro marketplace-hero" style="background-image: url(/assets/2025/08/banner-bg-scaled.png); background-size: cover; background-position: center top; background-repeat: no-repeat;">
	<div class="section__inner text-center" style="max-width: 1100px;">
		<span class="badge">Marketplace</span>
		<h1>Create and Deploy <span class="gradient-text">Interactive Avatars</span> for Any Use Case <span class="gradient-text--reverse">in Minutes</span></h1>
		<p style="max-width: 760px; margin-left: auto; margin-right: auto; color: var(--color-text-light);">Vendor agnostic, fully integrated with your ATS or CRM, and no engineering effort.</p>
		<div class="marketplace-vendor-logos">
			<span class="marketplace-vendor-logos__label">Powered by</span>
			<div class="marketplace-vendor-logos__row">
				<img src="/assets/2025/08/anam.png" alt="Anam" class="marketplace-vendor-logo" style="height: 24px;" />
				<img src="/assets/2025/08/tavus.svg" alt="Tavus" class="marketplace-vendor-logo" style="height: 22px;" />
				<img src="/assets/2025/08/heygen.svg" alt="HeyGen" class="marketplace-vendor-logo" style="height: 28px;" />
				<img src="/assets/2025/08/beyond-presence-dark.svg" alt="Beyond Presence" class="marketplace-vendor-logo" style="height: 30px;" />
			</div>
		</div>
	</div>
</section>

<!-- Two-Column: Steps + Use Cases -->
<section class="section marketplace-body-section">
	<div class="section__inner">
		<div class="marketplace-layout">

			<!-- LEFT COLUMN: Steps & Explanation -->
			<div class="marketplace-layout__left">
				<h2 style="margin-bottom: 30px;">How it works</h2>
				<div class="steps-vertical">
					<div class="step-v">
						<div class="step-v__number">1</div>
						<div class="step-v__content">
							<h4>Select Avatar</h4>
							<p>Choose from leading avatar vendors — voice-only or full video.</p>
						</div>
					</div>					<div class="step-v">
						<div class="step-v__number">2</div>
						<div class="step-v__content">
							<h4>Define Persona</h4>
							<p>Define personality, tone and domain expertise in plain language.</p>
						</div>
					</div>
					<div class="step-v">
						<div class="step-v__number">3</div>
						<div class="step-v__content">
							<h4>Connect ATS/CRM</h4>
							<p>Connect your CRM, ATS, LMS or any system via pre-built connectors.</p>
						</div>
					</div>
					<div class="step-v">
						<div class="step-v__number">4</div>
						<div class="step-v__content">
							<h4>Configure Workflow</h4>
							<p>Set triggers, post-session actions and data routing rules.</p>
						</div>
					</div>
					<div class="step-v">
						<div class="step-v__number">5</div>
						<div class="step-v__content">
							<h4>Preview Experience</h4>
							<p>Test your avatar in a sandbox before going live — refine tone, flows and responses.</p>
						</div>
					</div>
					<div class="step-v">
						<div class="step-v__number">6</div>
						<div class="step-v__content">
							<h4>Deploy Live</h4>
							<p>Go live on your website, app or meeting platform instantly.</p>
						</div>
					</div>
				</div>
			</div>

			<!-- RIGHT COLUMN: Tabbed Use Cases -->
			<div class="marketplace-layout__right">
				<div class="marketplace-tabs-card" data-tabs>
					<div class="tabs__nav tabs__nav--pills" style="justify-content: center; margin-bottom: 30px;">
						{% for uc in stackone.useCases %}
						<button class="tabs__btn{% if loop.first %} is-active{% endif %}" data-tab="{{ uc.id }}">{{ uc.label }}</button>
						{% endfor %}
					</div>

					{% set ucImages = {
						"recruitment": "/assets/2026/02/avatar-recruitment-2.jpg",
						"sales": "/assets/2026/02/avatar-sales-2.png",
						"tutoring": "/assets/2026/02/avatar-tutoring-2.jpg",
						"coaching": "/assets/2026/02/avatar-coaching.jpg",
						"onboarding": "/assets/2026/02/avatar-onboarding-2.jpg",
						"meetingbot": "/assets/2026/02/avatar-sales.jpg",
						"sdr": "/assets/2026/02/avatar-sales-2.png"
					} %}

					{% set ucFeatures = {
						"recruitment": [
							["Hire in days, not weeks", "Hiring cycles cut from 42 days to under a week. Time to first interview down 90%."],
							["Live in 1–2 weeks", "High-impact, light-lift. Live in under two weeks."],
							["Consistent. Fair. Always on.", "Same experience for every candidate. No qualified person left behind."],
							["Free your recruiters", "Less admin. More judgment, persuasion, and human connection."],
							["Built-in fraud detection", "Tab-switch alerts, camera checks, and voice-dupe detection on every session."],
							["Scales with your ATS", "Connects to your ATS and turns pipeline data into real-time insights."]
						],
						"sales": [
							["ICP-qualified only", "Avatar screens against your criteria before any lead reaches your team."],
							["Handles objections 24/7", "Trained on your product and messaging. Answers questions around the clock."],
							["Books meetings automatically", "Qualifies and drops straight into your team's calendar. No rep needed."],
							["CRM-synced", "Every conversation scored and pushed to your CRM in real time."],
							["Always on", "Qualifies inbound leads at any hour, in any time zone."],
							["Live in days", "Connect your CRM, configure your ICP, deploy in under a week."]
						],
						"tutoring": [
							["Adapts in real time", "Pace and depth adjust based on what the learner actually says."],
							["Surfaces knowledge gaps", "Probes understanding with follow-up questions, not just multiple choice."],
							["LMS integration", "Session summaries and scores pushed to your LMS automatically."],
							["24/7 access", "Always available on any device, at any time."],
							["Per-learner analytics", "Detailed progress tracking to guide human intervention where it matters."],
							["Deploy fast", "Connect your content, go live in under two weeks."]
						],
						"coaching": [
							["Structured sessions at scale", "Deliver consistent, high-quality coaching to every employee — without the overhead."],
							["Performance-linked", "Coaching scores and outcomes written back to your CRM or HRIS automatically."],
							["Always available", "On-demand coaching any time, on any device."],
							["Progress tracking", "Full session history and analytics per coachee."],
							["Manager visibility", "Summaries sent to the manager or HR partner after every session."],
							["Live in days", "Connect your system, configure your coaching flow, deploy fast."]
						],
						"onboarding": [
							["No coordinator needed", "Deploy once, runs for every hire. No scheduling, no hand-holding."],
							["Role-adaptive", "Content adjusts automatically based on role, team, and start date."],
							["Always consistent", "Every new hire gets the same quality experience, every time."],
							["Auto-logged", "All responses captured and pushed to your HRIS automatically."],
							["Live in under a week", "Configure once, deploy fast. High-impact and light lift."],
							["Scales instantly", "Handle 1 or 1,000 new starters simultaneously, with zero extra effort."]
						],
						"meetingbot": [
							["Joins any meeting", "Works with Zoom, Teams, Google Meet and more. No downloads needed."],
							["Real-time notes", "Captures decisions, action items, and key moments as they happen."],
							["CRM-synced", "Every meeting summary pushed to the right record automatically."],
							["Action item tracking", "AI detects and creates tasks from conversation in real time."],
							["Full transcript", "Searchable, timestamped transcript attached to every meeting record."],
							["Live in minutes", "Authorise your calendar, connect your CRM, done."]
						],
						"sdr": [
							["Outbound at scale", "Run hundreds of personalised outreach conversations simultaneously."],
							["ICP-qualified leads only", "Only qualified prospects reach your AEs. No time wasted."],
							["Books discovery calls", "Qualifies and books directly into your AE's calendar."],
							["CRM-synced", "Every call scored and logged to your CRM in real time."],
							["24/7 outreach", "Reaches prospects in any time zone, at any hour."],
							["Live in days", "Connect your CRM, configure your ICP, deploy in under a week."]
						]
					} %}

					{% for uc in stackone.useCases %}
					<div class="tabs__panel{% if loop.first %} is-active{% endif %}" data-tab-panel="{{ uc.id }}">
						<div class="marketplace-usecase">
							<img src="{{ ucImages[uc.id] }}" alt="{{ uc.label }} Avatar" class="marketplace-usecase__img" />
							<div class="marketplace-usecase__body">
								<div class="usecase-features">
									{% for feature in ucFeatures[uc.id] %}
									<div class="usecase-feature">
										<p class="usecase-feature__title">{{ feature[0] }}</p>
										<p class="usecase-feature__desc">{{ feature[1] }}</p>
									</div>
									{% endfor %}
								</div>

							</div>
						</div>
					</div>
					{% endfor %}

				</div>
			</div>

		</div>
	</div>
</section>

<!-- Bottom CTA -->
<section class="section" style="padding: 70px 0 90px;">
	<div class="section__inner text-center" style="max-width: 1100px;">
		<h1 style="margin: 0 auto; white-space: nowrap;">Go live in 15 minutes. No code. No limits.</h1>
		<p style="max-width: 600px; margin: 20px auto 0; color: var(--color-text-light);">Pick your vendor, connect your systems, deploy your avatar. It's that simple.</p>
		<a class="btn btn--primary" href="/demo/" style="margin-top: 30px;">
			<span>Get Started</span>
			<span class="btn__arrow">&rarr;</span>
		</a>
	</div>
</section>